# Backend environment example (production-focused)
# Copy to .env and replace placeholders where needed.

NODE_ENV=production
PORT=3000
MONGODB_URI=YOUR_MONGODB_URI_HERE

# Keep both false in production to avoid simulated data overriding real hardware data.
SEED_DATABASE=false
ENABLE_SIMULATION=false
SEED_READING_BATCH_SIZE=1000

# Meter insights defaults
TARIFF_PER_KWH=8
CO2_KG_PER_KWH=0.82
HIGH_USAGE_THRESHOLD_WATTS=5000

# ESP ingestion defaults
ESP_DEFAULT_METER_ID=MTR-1001

# Important: Render/cloud cannot read your local COM port. Keep serial disabled in production.
ESP_SERIAL_ENABLED=false
ESP_SERIAL_PORT=
ESP_SERIAL_BAUD_RATE=9600
ESP_SERIAL_RECONNECT_MS=3000

# Set true temporarily to print detailed ESP ingest logs in backend console.
ESP_DEBUG_LOGS=true

# Optional API key for /api/esp/readings and /api/esp/status
# If set, ESP firmware must send header: x-esp-api-key: <value>
ESP_API_KEY=
